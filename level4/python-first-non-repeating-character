user_input = input("Enter a word: ")
user_input1 = user_input.lower()

freq = {}

for i in user_input1:
    if i in freq:
        freq[i] += 1
    else:
        freq[i] = 1

found = False

for ch in user_input1:
    if freq[ch] == 1:
        print("First non-repeating character is:", ch)
        found = True
        break


if found == False:
    print("No non-repeating character found")
